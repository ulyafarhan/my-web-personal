---
import LayoutPublic from '@/layouts/LayoutPublic.astro';
import Pagination from '@/components/public/Pagination.astro';
import { getPaginatedPublishedProjects, getSettings } from '@/lib/content';

export const prerender = false;

const db = Astro.locals.runtime.env.DB;
const page = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);
const perPage = 9;

const [settings, { data: projects, totalPages, total }] = await Promise.all([
  getSettings(db),
  getPaginatedPublishedProjects(db, page, perPage),
]);

const showTotal = total > 0;
const pageTitle = page > 1 ? ` — Halaman ${page}` : '';
---

<LayoutPublic 
  title={`Semua Proyek${pageTitle} | ${settings.nama_pemilik}`} 
  description="Daftar proyek, riset, dan studi kasus teknis." 
  ownerName={settings.nama_pemilik} 
  email={settings.email_kontak}
>
  <section class="relative mx-auto max-w-7xl px-4 pb-32 pt-48 font-['Outfit'] overflow-hidden">
    <!-- Dynamic Background Ambient -->
    <div class="absolute left-[10%] top-[10%] h-[500px] w-[500px] bg-cyan-500/10 blur-[140px] pointer-events-none"></div>
    <div class="absolute right-[10%] bottom-[20%] h-[500px] w-[500px] bg-emerald-500/10 blur-[140px] pointer-events-none"></div>

    <div class="relative z-10 mb-20 max-w-4xl">
      <div class="mb-8 inline-flex items-center gap-2 rounded-md border border-white/10 bg-white/5 px-4 py-1.5 text-[10px] font-black uppercase tracking-[0.4em] text-cyan-400 backdrop-blur-md">
          Indeks Portofolio
      </div>
      <h1 class="text-5xl font-black tracking-tight text-white sm:text-7xl leading-[1.1]">Eksplorasi <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-emerald-400">Teknis & Karya.</span></h1>
      <p class="mt-8 text-lg leading-relaxed text-slate-400 max-w-2xl">Kumpulan rekayasa perangkat lunak, riset arsitektur sistem, dan studi kasus teknis yang dipublikasikan secara komprehensif.</p>
      {showTotal && (
        <p class="mt-4 text-sm text-slate-600">{total} proyek ditemukan</p>
      )}
    </div>

    <div class="relative z-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {projects.length === 0 ? (
        <div class="rounded-md border border-white/5 bg-[#080808] p-12 text-center text-slate-500 md:col-span-3">
            Belum ada proyek publik yang tersedia saat ini.
        </div>
      ) : projects.map((project) => (
        <a href={`/proyek/${project.slug}`} class="group relative overflow-hidden rounded-md border border-white/5 bg-[#080808] p-5 transition-all duration-700 hover:border-cyan-500/30 hover:-translate-y-1 shadow-2xl flex flex-col h-full">
          <!-- Image Container -->
          <div class="aspect-[16/10] overflow-hidden rounded-sm bg-black relative border border-white/5">
            {project.url_gambar_sampul ? (
              <img src={project.url_gambar_sampul} alt={project.judul} class="h-full w-full object-cover opacity-80 transition duration-700 group-hover:scale-105 group-hover:opacity-100" />
            ) : (
              <div class="absolute inset-0 bg-gradient-to-br from-slate-900 to-black">
                 <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(34,211,238,0.1),transparent_70%)]"></div>
              </div>
            )}
            <!-- Overlay Gradient -->
            <div class="absolute inset-0 bg-gradient-to-t from-[#080808] via-transparent to-transparent opacity-80"></div>
          </div>

          <!-- Content Container -->
          <div class="flex-1 pt-6 flex flex-col">
            <div class="mb-4 flex flex-wrap gap-2">
              {(project.tags || []).slice(0, 3).map((tag) => (
                <span class="text-[9px] font-bold uppercase tracking-widest text-cyan-400 border border-cyan-500/20 bg-cyan-500/5 px-2.5 py-1 rounded-sm">
                    {tag.nama}
                </span>
              ))}
            </div>
            <h2 class="text-2xl font-bold text-white group-hover:text-cyan-400 transition-colors duration-500 mb-3 line-clamp-2">{project.judul}</h2>
            <p class="text-sm leading-relaxed text-slate-500 line-clamp-3 mt-auto">{project.ringkasan}</p>
          </div>
          
          <!-- Animated Glow -->
          <div class="absolute inset-0 rounded-md ring-1 ring-inset ring-white/0 group-hover:ring-cyan-500/20 transition-all duration-700 pointer-events-none"></div>
        </a>
      ))}
    </div>

    <Pagination currentPage={page} totalPages={totalPages} baseUrl="/proyek" accentColor="cyan" />
  </section>
</LayoutPublic>

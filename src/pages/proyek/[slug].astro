---
import LayoutPublic from '@/layouts/LayoutPublic.astro';
import { getProjectBySlug, getSettings } from '@/lib/content';

export const prerender = false;

const db = Astro.locals.runtime.env.DB;
const slug = Astro.params.slug || '';
const [settings, proyek] = await Promise.all([
  getSettings(db),
  getProjectBySlug(db, slug),
]);

if (!proyek) {
  Astro.response.status = 404;
}

const sanitizeHtml = (html: string) => html
  .replace(/<script\b[^<]*(?:(?!<\/script>)<[^<]*)*<\/script>/gi, '')
  .replace(/<iframe\b[^<]*(?:(?!<\/iframe>)<[^<]*)*<\/iframe>/gi, '')
  .replace(/<object\b[^<]*(?:(?!<\/object>)<[^<]*)*<\/object>/gi, '')
  .replace(/\son[a-z]+\s*=\s*(['"]).*?\1/gi, '')
  .replace(/\s(href|src)\s*=\s*(['"])\s*javascript:.*?\2/gi, '');

const safeContent = proyek ? sanitizeHtml(proyek.konten_html) : '';
---

<LayoutPublic title={proyek ? `${proyek.judul} | ${settings.nama_pemilik}` : `Proyek Tidak Ditemukan | ${settings.nama_pemilik}`} description={proyek?.ringkasan || 'Proyek tidak ditemukan'} ownerName={settings.nama_pemilik} email={settings.email_kontak}>
  {proyek ? (
    <article class="relative mx-auto max-w-4xl px-4 pb-32 pt-32 font-['Outfit'] overflow-hidden">
      <!-- Dynamic Background Ambient -->
      <div class="absolute left-[-10%] top-[0%] h-[600px] w-[500px] bg-cyan-500/10 blur-[150px] pointer-events-none"></div>
      
      <div class="relative z-10">
        <a href="/proyek" class="inline-flex items-center gap-2 text-[11px] font-black uppercase tracking-[0.2em] text-cyan-400 hover:text-cyan-300 transition-colors mb-12">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Kembali ke Indeks
        </a>
        
        <div class="mb-6 flex flex-wrap gap-2">
          {(proyek.tags || []).map((tag) => (
            <span class="text-[10px] font-bold uppercase tracking-widest text-cyan-400 border border-cyan-500/20 bg-cyan-500/5 px-3 py-1.5 rounded-sm">
              {tag.nama}
            </span>
          ))}
        </div>
        
        <h1 class="text-5xl font-black tracking-tight text-white sm:text-7xl leading-[1.1]">{proyek.judul}</h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-400 max-w-3xl">{proyek.ringkasan}</p>
        
        <div class="mt-10 flex flex-wrap gap-4">
          {proyek.url_demo && (
            <a href={proyek.url_demo} target="_blank" class="group relative overflow-hidden rounded-full bg-white px-8 py-3.5 text-[11px] font-black uppercase tracking-widest text-black transition-all hover:bg-cyan-400 hover:shadow-[0_0_20px_rgba(34,211,238,0.4)]">
              Lihat Demo Langsung
            </a>
          )}
          {proyek.url_repo && (
            <a href={proyek.url_repo} target="_blank" class="rounded-full border border-white/10 bg-white/5 px-8 py-3.5 text-[11px] font-black uppercase tracking-widest text-white hover:bg-white/10 hover:border-white/20 transition-all">
              Repositori Kode
            </a>
          )}
        </div>
      </div>

      <!-- Cover Image (Bento Style) -->
      <div class="relative z-10 mt-16 overflow-hidden rounded-md border border-white/5 bg-black shadow-2xl">
        {proyek.url_gambar_sampul ? (
          <img src={proyek.url_gambar_sampul} alt={proyek.judul} class="w-full object-cover opacity-90" />
        ) : (
          <div class="aspect-[21/9] bg-gradient-to-br from-slate-900 to-black flex items-center justify-center">
             <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(34,211,238,0.1),transparent_70%)]"></div>
             <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-white/10"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="m3 9 18-18"/><path d="M14 21 21 14"/></svg>
          </div>
        )}
      </div>

      <!-- Main Content (Bento Style) -->
      <div class="relative z-10 prose-content mt-8 rounded-md border border-white/5 bg-[#080808] p-8 sm:p-12 shadow-2xl" set:html={safeContent}></div>
    </article>
  ) : (
    <section class="mx-auto max-w-3xl px-4 pb-32 pt-48 text-center font-['Outfit']">
      <div class="mb-6 mx-auto flex h-20 w-20 items-center justify-center rounded-full border border-red-500/20 bg-red-500/10 text-red-400">
         <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
      </div>
      <h1 class="text-5xl font-black text-white tracking-tight">Data Tidak Ditemukan</h1>
      <p class="mt-6 text-lg text-slate-400">Proyek teknis ini mungkin masih dalam tahap draf atau tautan telah diubah.</p>
      <a href="/proyek" class="mt-10 inline-flex rounded-full bg-white px-8 py-3.5 text-[11px] font-black uppercase tracking-widest text-black hover:bg-cyan-400 transition-all">Kembali ke Indeks</a>
    </section>
  )}
</LayoutPublic>

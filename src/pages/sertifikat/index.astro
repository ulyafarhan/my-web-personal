---
import LayoutPublic from '@/layouts/LayoutPublic.astro';
import Pagination from '@/components/public/Pagination.astro';
import { getPaginatedSertifikat, getSettings } from '@/lib/content';

export const prerender = false;

const db = Astro.locals.runtime.env.DB;
const page = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);
const perPage = 9;

const [settings, { data: sertifikat, totalPages, total }] = await Promise.all([
  getSettings(db),
  getPaginatedSertifikat(db, page, perPage),
]);

const showTotal = total > 0;
const pageTitle = page > 1 ? ` — Halaman ${page}` : '';
---

<LayoutPublic 
  title={`Semua Sertifikat${pageTitle} | ${settings.nama_pemilik}`} 
  description="Daftar lengkap sertifikasi dan pencapaian teknis." 
  ownerName={settings.nama_pemilik} 
  email={settings.email_kontak}
>
  <section class="relative mx-auto max-w-7xl px-4 pb-32 pt-48 font-['Outfit'] overflow-hidden">
    <!-- Dynamic Background Ambient -->
    <div class="absolute left-[10%] top-[10%] h-[500px] w-[500px] bg-emerald-500/10 blur-[140px] pointer-events-none"></div>

    <div class="relative z-10 mb-20 max-w-4xl">
      <div class="mb-8 inline-flex items-center gap-2 rounded-md border border-white/10 bg-white/5 px-4 py-1.5 text-[10px] font-black uppercase tracking-[0.4em] text-emerald-400 backdrop-blur-md">
          Indeks Pencapaian
      </div>
      <h1 class="text-5xl font-black tracking-tight text-white sm:text-7xl leading-[1.1]">Sertifikasi <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-400">Teknis.</span></h1>
      <p class="mt-8 text-lg leading-relaxed text-slate-400 max-w-2xl">Daftar lengkap kredensial, lisensi, dan sertifikasi keahlian teknologi dari berbagai institusi profesional.</p>
      {showTotal && (
        <p class="mt-4 text-sm text-slate-600">{total} sertifikat terdaftar</p>
      )}
    </div>

    <div class="relative z-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {sertifikat.length === 0 ? (
        <div class="rounded-md border border-white/5 bg-[#080808] p-12 text-center text-slate-500 md:col-span-3">
            Belum ada sertifikat yang tersedia saat ini.
        </div>
      ) : sertifikat.map((cert) => (
        <div class="group relative overflow-hidden rounded-md border border-white/5 bg-[#080808] p-8 transition-all duration-700 hover:border-emerald-500/30 hover:-translate-y-1 shadow-2xl flex flex-col h-full">
          <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-md border border-white/10 bg-white/5 text-emerald-400 group-hover:bg-emerald-500 group-hover:text-black transition-all">
             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/><path d="M19.5 10a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z"/><path d="m8.6 14.5 1.4 6.5 2-2.5 2 2.5 1.4-6.5"/></svg>
          </div>
          
          <div class="flex-1">
            <h4 class="text-xl font-bold text-white mb-2 group-hover:text-emerald-400 transition-colors">{cert.nama}</h4>
            <p class="text-sm font-medium text-slate-400 mb-4">{cert.penerbit} <span class="text-slate-600 ml-2">&bull;</span> <span class="text-emerald-500/80 ml-2">{cert.tahun}</span></p>
          </div>
          
          {cert.url_kredensial && (
            <a href={cert.url_kredensial} target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-emerald-400 hover:text-emerald-300 transition-colors w-fit">
              Lihat Kredensial
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
            </a>
          )}
          
          <!-- Animated Glow -->
          <div class="absolute inset-0 rounded-md ring-1 ring-inset ring-white/0 group-hover:ring-emerald-500/20 transition-all duration-700 pointer-events-none"></div>
        </div>
      ))}
    </div>

    <Pagination currentPage={page} totalPages={totalPages} baseUrl="/sertifikat" accentColor="emerald" />
  </section>
</LayoutPublic>

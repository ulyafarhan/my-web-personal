---
import "@/styles/app.css";
import Sidebar from "@/components/admin/Sidebar.astro";
import Header from "@/components/admin/Header.astro";

interface Props {
  title: string;
  subtitle?: string;
  breadcrumbs?: { label: string; href?: string }[];
}

const {
  title,
  subtitle = "Overview of your portfolio and system performance.",
  breadcrumbs = [],
} = Astro.props;

const currentPath = Astro.url.pathname;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="id" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Premium Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --sidebar-width: 280px;
        --header-height: 64px;
        font-family: "Outfit", sans-serif;
      }
      body {
        background-color: #020617;
        overflow-x: hidden;
      }
      .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
      }
      .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
      }
      .glass-effect {
        background: rgba(2, 6, 23, 0.8);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
      }
    </style>
  </head>
  <body
    class="min-h-screen text-slate-200 antialiased selection:bg-cyan-500/30"
  >
    <div class="flex min-h-screen relative">
      <Sidebar user={user} currentPath={currentPath} />

      <div
        id="contentWrapper"
        class="flex-1 flex flex-col min-w-0 transition-all duration-300"
      >
        <Header breadcrumbs={breadcrumbs} />

        <main class="flex-1 overflow-x-hidden">
          <div class="p-4 sm:p-6 lg:p-10 mx-auto max-w-full">
            <div class="mb-8 lg:mb-12">
              <h1
                class="text-2xl sm:text-3xl lg:text-4xl font-black tracking-tight text-white"
              >
                {title}
              </h1>
              <p
                class="mt-2 text-xs sm:text-sm font-medium text-slate-500 max-w-3xl leading-relaxed"
              >
                {subtitle}
              </p>
            </div>
            <slot />
          </div>
        </main>
      </div>

      <div
        id="sidebarBackdrop"
        class="fixed inset-0 z-40 hidden bg-slate-950/80 backdrop-blur-sm lg:hidden transition-opacity duration-300"
      >
      </div>
    </div>

    <script>
      const sidebar = document.getElementById("adminSidebar");
      const backdrop = document.getElementById("sidebarBackdrop");
      const openBtn = document.querySelector("[data-open-sidebar]");
      const closeBtn = document.querySelector("[data-close-sidebar]");

      const toggleSidebar = (show: boolean) => {
        if (!sidebar || !backdrop) return;
        if (show) {
          sidebar.classList.remove("-translate-x-full");
          backdrop.classList.remove("hidden");
          document.body.style.overflow = "hidden";
        } else {
          sidebar.classList.add("-translate-x-full");
          backdrop.classList.add("hidden");
          document.body.style.overflow = "";
        }
      };

      openBtn?.addEventListener("click", () => toggleSidebar(true));
      closeBtn?.addEventListener("click", () => toggleSidebar(false));
      backdrop?.addEventListener("click", () => toggleSidebar(false));

      document
        .getElementById("btnLogout")
        ?.addEventListener("click", async (e) => {
          e.preventDefault();
          if (confirm("Akhiri sesi administrasi sekarang?")) {
            try {
              const btn = e.currentTarget as HTMLButtonElement;
              btn.disabled = true;
              btn.innerHTML =
                '<svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>';

              const res = await fetch("/api/auth/sign-out", {
                method: "POST",
                headers: { Accept: "application/json" },
              });

              if (res.ok) {
                window.location.href = "/masuk";
              } else {
                alert("Gagal keluar sesi. Silakan coba lagi.");
                btn.disabled = false;
                btn.innerHTML =
                  '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>';
              }
            } catch (err) {
              console.error("Logout error:", err);
              window.location.reload();
            }
          }
        });
    </script>
  </body>
</html>

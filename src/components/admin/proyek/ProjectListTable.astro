---
import { Button } from "@/components/ui/button";

interface Tag {
  id: string;
  nama: string;
}

interface Project {
  id: string;
  judul: string;
  slug: string;
  status_publikasi: number;
  view_count: number;
  tags?: Tag[];
}

interface Props {
  proyek: Project[];
}

const { proyek } = Astro.props;
---

<div class="overflow-x-auto custom-scrollbar">
  <table class="w-full text-left text-sm">
    <thead>
      <tr
        class="border-b border-white/5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-500"
      >
        <th class="px-6 py-5">Identitas Proyek</th>
        <th class="hidden px-6 py-5 md:table-cell">Stack</th>
        <th class="px-6 py-5">Visibilitas</th>
        <th class="hidden px-6 py-5 sm:table-cell">Metrik</th>
        <th class="px-6 py-5 text-right">Opsi</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-white/5">
      {
        proyek.length === 0 ? (
          <tr>
            <td
              colspan="5"
              class="px-6 py-16 text-center text-sm text-slate-500 italic"
            >
              Belum ada repositori proyek. Mulailah membangun portofolio Anda.
            </td>
          </tr>
        ) : (
          proyek.map((p) => (
            <tr class="group transition-colors hover:bg-white/[0.02]">
              <td class="px-6 py-5">
                <div class="font-bold text-white group-hover:text-cyan-400 transition-colors">
                  {p.judul}
                </div>
                <div class="mt-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest">
                  /{p.slug}
                </div>
              </td>
              <td class="hidden px-6 py-5 md:table-cell">
                <div class="flex max-w-[200px] flex-wrap gap-1.5">
                  {(p.tags || []).slice(0, 3).map((tag) => (
                    <span class="rounded-l border border-white/5 bg-white/5 px-2 py-1 text-[9px] font-bold text-slate-400">
                      {tag.nama}
                    </span>
                  ))}
                  {(p.tags || []).length > 3 && (
                    <span class="text-[9px] text-slate-600 font-bold">
                      +{p.tags!.length - 3}
                    </span>
                  )}
                </div>
              </td>
              <td class="px-6 py-5">
                <span
                  class:list={[
                    "inline-flex items-center gap-1.5 rounded-l px-2.5 py-1 text-[9px] font-black uppercase tracking-widest",
                    p.status_publikasi === 1
                      ? "bg-emerald-500/10 text-emerald-400"
                      : "bg-amber-500/10 text-amber-400",
                  ]}
                >
                  <span
                    class:list={[
                      "h-1.5 w-1.5 rounded-full animate-pulse",
                      p.status_publikasi === 1
                        ? "bg-emerald-400"
                        : "bg-amber-400",
                    ]}
                  />
                  {p.status_publikasi === 1 ? "Public" : "Draft"}
                </span>
              </td>
              <td class="hidden px-6 py-5 sm:table-cell">
                <div class="flex items-center gap-2 text-slate-400">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="opacity-50"
                  >
                    <>
                      <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
                      <circle cx="12" cy="12" r="3" />
                    </>
                  </svg>
                  <span class="text-xs font-bold font-mono">
                    {p.view_count ?? 0}
                  </span>
                </div>
              </td>
              <td class="px-6 py-5">
                <div class="flex justify-end gap-2">
                  <a
                    href={`/proyek/${p.slug}`}
                    target="_blank"
                    class="rounded-full bg-white/5 p-2 text-slate-400 hover:bg-white/10 hover:text-white transition-all"
                    title="Pratinjau"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <>
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                        <polyline points="15 3 21 3 21 9" />
                        <line x1="10" x2="21" y1="14" y2="3" />
                      </>
                    </svg>
                  </a>
                  <a
                    href={`/admin/proyek/tambah?id=${p.id}`}
                    class="rounded-full bg-white/5 p-2 text-cyan-400 hover:bg-cyan-500/10 transition-all"
                    title="Edit"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <>
                        <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" />
                        <path d="m15 5 4 4" />
                      </>
                    </svg>
                  </a>
                  <button
                    data-delete-project={p.id}
                    class="rounded-full bg-white/5 p-2 text-red-400 hover:bg-red-500/10 transition-all"
                    title="Hapus"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <>
                        <path d="M3 6h18" />
                        <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" />
                        <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" />
                        <line x1="10" x2="10" y1="11" y2="17" />
                        <line x1="14" x2="14" y1="11" y2="17" />
                      </>
                    </svg>
                  </button>
                </div>
              </td>
            </tr>
          ))
        )
      }
    </tbody>
  </table>
</div>

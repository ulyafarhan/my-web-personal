---
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from "@/components/ui/card";
import { Button } from "@/components/ui/button";

import type { Keahlian } from "@/lib/content";

interface Props {
  keahlian: Keahlian[];
}

const { keahlian } = Astro.props;
---

<Card class="border-white/5 bg-white/[0.01]">
  <CardHeader class="border-b border-white/5 pb-6">
    <div class="flex items-center justify-between">
      <div>
        <CardTitle class="text-xl font-bold text-white">Daftar Keahlian</CardTitle>
        <CardDescription>Skill teknis yang ditampilkan dalam chart di halaman beranda.</CardDescription>
      </div>
      <span class="rounded-full bg-violet-500/10 px-3 py-1 text-[10px] font-black uppercase tracking-widest text-violet-400 ring-1 ring-violet-500/20">
        {keahlian.length} Entri
      </span>
    </div>
  </CardHeader>
  <CardContent class="p-0">
    <div class="divide-y divide-white/5">
      {keahlian.length === 0 ? (
        <div class="p-12 text-center text-sm text-slate-500 italic">Belum ada keahlian terdaftar.</div>
      ) : (
        keahlian.map((item) => (
          <div class="group p-6 hover:bg-white/[0.02] transition-all">
            <div class="flex items-center justify-between gap-4">
              <div class="flex items-center gap-4 flex-1 min-w-0">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-white/5 text-sm font-black text-violet-400 group-hover:bg-violet-500/10 transition-colors">
                  {item.persentase}%
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3">
                    <h3 class="font-bold text-white group-hover:text-violet-400 transition-colors truncate">{item.nama}</h3>
                    {item.kategori && (
                      <span class="hidden sm:inline-flex rounded-full bg-white/5 px-2 py-0.5 text-[9px] font-bold uppercase tracking-widest text-slate-500 border border-white/5">
                        {item.kategori}
                      </span>
                    )}
                  </div>
                  <!-- Mini bar preview -->
                  <div class="mt-2 h-1.5 w-full max-w-[200px] rounded-full bg-white/5 overflow-hidden">
                    <div
                      class="h-full rounded-full transition-all duration-500"
                      style={`width: ${item.persentase}%; background: ${item.warna || 'rgb(34, 211, 238)'}`}
                    ></div>
                  </div>
                </div>
              </div>
              <div class="flex items-center gap-1">
                <Button 
                  variant="ghost" 
                  size="icon" 
                  data-edit-skill={JSON.stringify(item)}
                  class="rounded-full h-9 w-9 text-slate-400 hover:text-violet-400 hover:bg-violet-500/10"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                </Button>
                <Button 
                  variant="ghost" 
                  size="icon" 
                  data-delete-skill={item.id}
                  class="rounded-full h-9 w-9 text-slate-400 hover:text-red-400 hover:bg-red-500/10"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                </Button>
              </div>
            </div>
          </div>
        ))
      )}
    </div>
  </CardContent>
</Card>

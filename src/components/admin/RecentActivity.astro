---
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from "@/components/ui/card";
import { Button } from "@/components/ui/button";

interface Project {
  id: string;
  judul: string;
  slug: string;
  status_publikasi: number;
  created_at: string;
}

interface Props {
  recentProjects: Project[];
}

const { recentProjects } = Astro.props;
---

<Card class="recent-activity-section border-white/5 bg-white/[0.01]">
  <CardHeader
    class="flex flex-row items-center justify-between border-b border-white/5 pb-6"
  >
    <div>
      <CardTitle class="text-lg font-bold text-white"
        >Log Aktivitas Proyek</CardTitle
      >
      <CardDescription class="text-xs"
        >Dokumentasi teknis terbaru yang diterbitkan.</CardDescription
      >
    </div>
    <Button
      as="a"
      href="/admin/proyek/tambah"
      size="sm"
      class="rounded-full font-bold bg-cyan-500 text-slate-950 hover:bg-cyan-400"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="mr-2"
        ><path d="M5 12h14"></path><path d="M12 5v14"></path></svg
      >
      Entri Baru
    </Button>
  </CardHeader>
  <CardContent class="p-0">
    <div class="divide-y divide-white/5">
      {
        recentProjects.length === 0 ? (
          <div class="p-12 text-center text-sm text-slate-500 italic">
            Belum ada aktivitas tercatat.
          </div>
        ) : (
          recentProjects.map((project) => (
            <div class="group flex items-center justify-between p-6 hover:bg-white/[0.02] transition-colors">
              <div class="flex items-center gap-4">
                <div
                  class:list={[
                    "flex h-10 w-10 items-center justify-center rounded-md",
                    project.status_publikasi === 1
                      ? "bg-emerald-500/10 text-emerald-400"
                      : "bg-amber-500/10 text-amber-400",
                  ]}
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-bold text-white group-hover:text-cyan-400 transition-colors">
                    {project.judul}
                  </h4>
                  <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mt-1">
                    /{project.slug} •{" "}
                    {new Date(project.created_at).toLocaleDateString(
                      "id-ID",
                    )}
                  </p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <span
                  class:list={[
                    "rounded-md px-2 py-1 text-[9px] font-black uppercase tracking-widest",
                    project.status_publikasi === 1
                      ? "bg-emerald-500/10 text-emerald-400"
                      : "bg-amber-500/10 text-amber-400",
                  ]}
                >
                  {project.status_publikasi === 1 ? "Public" : "Draft"}
                </span>
                <a
                  href={`/admin/proyek/tambah?id=${project.id}`}
                  class="rounded-full bg-white/5 p-2 text-slate-400 hover:bg-white/10 hover:text-white transition-all"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" />
                    <path d="m15 5 4 4" />
                  </svg>
                </a>
              </div>
            </div>
          ))
        )
      }
    </div>
  </CardContent>
</Card>

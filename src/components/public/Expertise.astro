           </div>

           <div class="absolute bottom-0 right-0 p-6 opacity-20 pointer-events-none">
              <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-500"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>
           </div>
        </div>
      </div>

      <!-- Small Card: AI Integration -->
      <div class="stagger-item group relative overflow-hidden rounded-md border border-white/5 bg-[#080808]/80 p-8 transition-all duration-700 hover:border-purple-500/30">
        <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-md border border-white/10 bg-white/5 text-purple-400 group-hover:bg-purple-500 group-hover:text-black transition-all">
           <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>
        </div>
        <h4 class="text-xl font-bold text-white mb-2">Integrasi AI</h4>
        <p class="text-sm text-slate-500">Memanfaatkan RAG dan vector embedding untuk agen cerdas.</p>
        <div class="absolute -right-4 -bottom-4 h-24 w-24 rounded-full bg-purple-500/5 blur-2xl group-hover:bg-purple-500/20 transition-all"></div>
      </div>

      <!-- Small Card: Infrastructure -->
      <div class="stagger-item group relative overflow-hidden rounded-md border border-white/5 bg-[#080808]/80 p-8 transition-all duration-700 hover:border-blue-500/30">
        <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-md border border-white/10 bg-white/5 text-blue-400 group-hover:bg-blue-500 group-hover:text-black transition-all">

                    <div class="w-full bg-cyan-500/20 rounded-t-sm h-[40%] group-hover:h-[60%] transition-all duration-700"></div>
                    <div class="w-full bg-cyan-500/40 rounded-t-sm h-[70%] group-hover:h-[40%] transition-all duration-1000"></div>
                    <div class="w-full bg-cyan-500/60 rounded-t-sm h-[50%] group-hover:h-[80%] transition-all duration-500"></div>
                 </div>
              </div>
              <!-- Mini UI Component 2: Circle Graph -->
              <div class="aspect-square rounded-md border border-white/5 bg-white/[0.02] flex items-center justify-center group-hover:border-cyan-500/30 transition-all overflow-hidden relative">
                 <div class="h-8 w-8 rounded-full border-2 border-dashed border-cyan-500/20 animate-spin-slow"></div>
                 <div class="absolute h-4 w-4 rounded-full bg-cyan-500/40 blur-sm"></div>
              </div>
              <!-- Mini UI Component 3: Layout -->
              <div class="aspect-square rounded-md border border-white/5 bg-white/[0.02] p-2 flex flex-col gap-1.5 group-hover:border-cyan-500/30 transition-all">
                 <div class="h-2 w-full rounded-full bg-white/5"></div>
                 <div class="h-2 w-2/3 rounded-full bg-white/5"></div>
                 <div class="mt-auto h-4 w-full rounded-sm bg-cyan-500/20"></div>
              </div>
              <!-- Mini UI Component 4: Toggle -->
              <div class="aspect-square rounded-md border border-white/5 bg-white/[0.02] flex items-center justify-center group-hover:border-cyan-500/30 transition-all">
                 <div class="h-3 w-6 rounded-full bg-white/10 relative">
                    <div class="absolute left-0.5 top-0.5 h-2 w-2 rounded-full bg-cyan-400 group-hover:translate-x-3 transition-transform duration-500"></div>
                 </div>
              </div>
              <!-- Mini UI Component 5: Nodes -->
              <div class="aspect-square rounded-md border border-white/5 bg-white/[0.02] flex items-center justify-center group-hover:border-cyan-500/30 transition-all relative">
                 <div class="h-1 w-1 rounded-full bg-cyan-400 shadow-[0_0_10px_#22d3ee]"></div>
                 <div class="absolute inset-0 flex items-center justify-center">
                    <div class="h-8 w-8 rounded-full border border-cyan-500/10 scale-0 group-hover:scale-150 opacity-0 group-hover:opacity-100 transition-all duration-1000"></div>
                 </div>
              </div>
              <!-- Mini UI Component 6: Cursor -->
              <div class="aspect-square rounded-md border border-white/5 bg-white/[0.02] flex items-center justify-center group-hover:border-cyan-500/30 transition-all">
                 <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-400/40 group-hover:text-cyan-400 transition-colors"><path d="m3 3 7.07 16.97 2.51-7.39 7.39-2.51L3 3z"/><path d="m13 13 6 6"/></svg>
              </div>
           </div>
        </div>
      </div>
    </div>
  </div>
</section>
<script>
  function startTypingEffect() {
    const target = document.getElementById('typing-code');
    const cursor = document.getElementById('typing-cursor');
    if (!target || !cursor) return;

    const codeContent = [
      '<span class="text-emerald-400">class</span> <span class="text-white">CoreService</span> {',
      '  <span class="text-emerald-400">private</span> <span class="text-cyan-400">repo</span>: Repository;',
      '  <span class="text-emerald-400">public</span> <span class="text-white">fetchData</span>() {',
      '    <span class="text-slate-500">// Logic cloud skalabel</span>',
      '    <span class="text-emerald-400">return</span> <span class="text-cyan-400">this</span>.repo.get();',
      '  }',
      '}'
    ].join('\n');

    let currentText = '';
    let index = 0;
    let isTag = false;

    function type() {
      if (index < codeContent.length) {
        let char = codeContent[index];
        
        if (char === '<') isTag = true;
        if (char === '>') {
           isTag = false;
           currentText += char;
           index++;
           type(); // Skip the tag closing
           return;
        }

        currentText += char;
        index++;

        if (isTag) {
          type();
        } else {
          if (target) {
            target.innerHTML = currentText;
            const rects = target.getClientRects();
            if (rects.length > 0) {
              const lastRect = rects[rects.length - 1];
            }
          }
          setTimeout(type, Math.random() * 30 + 20);
        }
      } else {
        // Reset or stay
        setTimeout(() => {
          currentText = '';
          index = 0;
          type();
        }, 5000);
      }
    }

    type();
  }

  function initExpertiseTyping() {
    const section = document.getElementById('keahlian');
    if (!section) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          startTypingEffect();
          observer.disconnect();
        }
      });
    }, { 
      threshold: 0.1, // Lower threshold for mobile compatibility
      rootMargin: '0px 0px -100px 0px' // Trigger slightly before it hits the center
    });

    observer.observe(section);
  }

  // Handle both initial load and Astro view transitions
  initExpertiseTyping();
  document.addEventListener('astro:page-load', initExpertiseTyping);
</script>


<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-spin-slow {
    animation: spin-slow 12s linear infinite;
  }

  #typing-cursor {
    animation: blink 0.8s step-end infinite;
    display: inline-block;
    vertical-align: middle;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>


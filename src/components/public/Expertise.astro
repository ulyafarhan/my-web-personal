      <!-- Big Card: Backend Architecture -->
      <div class="stagger-item md:col-span-2 lg:col-span-2 row-span-2 group relative overflow-hidden rounded-md border border-white/5 bg-[#080808]/80 p-10 transition-all duration-700 hover:border-emerald-500/30 shadow-2xl">


        </div>

        <!-- Visual Mockup Inside Bento -->
        <div class="mt-12 relative h-64 rounded-md border border-white/10 bg-black/40 p-6 backdrop-blur-xl overflow-hidden group-hover:translate-y-[-5px] transition-transform duration-700">

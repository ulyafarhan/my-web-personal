              <div class="h-2.5 w-2.5 rounded-full bg-red-500/30"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-amber-500/30"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-emerald-500/30"></div>
           </div>
           
           <div class="font-mono text-[11px] leading-relaxed relative">

           <div class="flex-1 w-full grid grid-cols-3 gap-3">
              <!-- Mini UI Component 1: Chart -->
              <div class="aspect-square rounded-md border border-white/5 bg-white/[0.02] p-2 flex flex-col justify-end gap-1 group-hover:border-cyan-500/30 transition-all">

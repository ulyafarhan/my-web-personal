---
interface Props {
  email: string;
}

const { email } = Astro.props;
---

<div id="mobile-overlay" class="fixed inset-0 top-[72px] z-[90] hidden px-4 pointer-events-auto">
  <div class="flex flex-col gap-1 rounded-2xl border border-white/[0.06] bg-black/90 p-4 shadow-[0_16px_48px_rgba(0,0,0,0.6)] backdrop-blur-3xl mt-2">
     <p class="px-4 pt-2 pb-1 text-[9px] font-bold uppercase tracking-[0.3em] text-white/20">Beranda</p>
     <a href="/#keahlian" class="mobile-link rounded-xl px-4 py-2.5 text-[13px] font-semibold text-white/70 transition-colors hover:text-cyan-400" data-section="keahlian">Keahlian</a>
     <a href="/#karya" class="mobile-link rounded-xl px-4 py-2.5 text-[13px] font-semibold text-white/70 transition-colors hover:text-cyan-400" data-section="karya">Karya</a>
     <a href="/#pengalaman" class="mobile-link rounded-xl px-4 py-2.5 text-[13px] font-semibold text-white/70 transition-colors hover:text-cyan-400" data-section="pengalaman">Pengalaman</a>
     <a href="/#sertifikasi" class="mobile-link rounded-xl px-4 py-2.5 text-[13px] font-semibold text-white/70 transition-colors hover:text-cyan-400" data-section="sertifikasi">Sertifikat</a>
     <div class="mx-4 my-2 h-px bg-white/[0.06]"></div>
     <p class="px-4 pt-1 pb-1 text-[9px] font-bold uppercase tracking-[0.3em] text-white/20">Halaman</p>
     <a href="/pengalaman" class="mobile-link rounded-xl px-4 py-2.5 text-[13px] font-semibold text-white/70 transition-colors hover:text-cyan-400">Pengalaman</a>
     <a href="/proyek" class="mobile-link rounded-xl px-4 py-2.5 text-[13px] font-semibold text-white/70 transition-colors hover:text-cyan-400">Portofolio</a>
     <a href="/sertifikat" class="mobile-link rounded-xl px-4 py-2.5 text-[13px] font-semibold text-white/70 transition-colors hover:text-cyan-400">Sertifikat</a>
     <div class="mx-4 my-2 h-px bg-white/[0.06]"></div>
     <a href={`mailto:${email}`} class="mobile-link rounded-xl px-4 py-2.5 text-[13px] font-semibold text-cyan-400/80 transition-colors hover:text-cyan-400">Hubungi Saya</a>
  </div>
</div>

---
// src/components/public/OtherSkills.astro
---
<section id="skill-lainnya" class="reveal relative py-20 px-8 sm:px-12 lg:px-20 overflow-hidden font-['Outfit']">
  <!-- Ambient Background -->
  <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-[400px] w-[600px] bg-cyan-500/5 blur-[120px] pointer-events-none"></div>

  <div class="mx-auto max-w-7xl relative z-10 mb-12">
    <!-- Header -->
    <div class="text-center">
      <h2 class="text-[10px] font-black uppercase tracking-[0.6em] text-cyan-400">Beyond Code</h2>
      <h3 class="mt-3 text-3xl font-black text-white sm:text-4xl tracking-tight leading-tight">Skill <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-violet-400">Lainnya.</span></h3>
    </div>
  </div>

  <div class="relative flex overflow-hidden w-full group max-w-screen-2xl mx-auto" style="mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent); -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);">
    <!-- Scrolling Track -->
    <div class="flex w-max animate-marquee group-hover:pause-animation items-center py-4">

      
      <!-- We use 3 identical sets for maximum performance while maintaining seamless loop -->
      {[1, 2, 3].map(() => (
        <div class="flex gap-6 pr-6 shrink-0">
          
          <!-- Designer -->
          <div class="flex items-center gap-5 px-8 py-5 rounded-full border border-white/10 bg-white/[0.03] backdrop-blur-md transition-all duration-500 hover:border-cyan-500/30 hover:bg-cyan-500/[0.05] group/item cursor-default shadow-2xl">
            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-cyan-500/10 text-cyan-400 shadow-[0_0_20px_rgba(34,211,238,0.15)] transition-transform duration-500 group-hover/item:scale-110">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5"/><circle cx="17.5" cy="10.5" r=".5"/><circle cx="8.5" cy="7.5" r=".5"/><circle cx="6.5" cy="12.5" r=".5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>
            </div>
            <div>
              <h4 class="text-xl font-bold text-white group-hover/item:text-cyan-300 transition-colors whitespace-nowrap">Designer</h4>
              <p class="text-[10px] font-bold uppercase tracking-widest text-cyan-400/60 mt-1">Creative</p>
            </div>
          </div>

          <!-- Videografer -->
          <div class="flex items-center gap-5 px-8 py-5 rounded-full border border-white/10 bg-white/[0.03] backdrop-blur-md transition-all duration-500 hover:border-violet-500/30 hover:bg-violet-500/[0.05] group/item cursor-default shadow-2xl">
            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-violet-500/10 text-violet-400 shadow-[0_0_20px_rgba(139,92,246,0.15)] transition-transform duration-500 group-hover/item:scale-110">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.2 6 3 11l-.9-2.4c-.3-1.1.3-2.2 1.3-2.5l13.5-4c1.1-.3 2.2.3 2.5 1.3Z"/><path d="m6.2 5.3 3.1 3.9"/><path d="m12.4 3.4 3.1 4"/><path d="M3 11h18v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z"/></svg>
            </div>
            <div>
              <h4 class="text-xl font-bold text-white group-hover/item:text-violet-300 transition-colors whitespace-nowrap">Videografer</h4>
              <p class="text-[10px] font-bold uppercase tracking-widest text-violet-400/60 mt-1">Multimedia</p>
            </div>
          </div>

          <!-- Office -->
          <div class="flex items-center gap-5 px-8 py-5 rounded-full border border-white/10 bg-white/[0.03] backdrop-blur-md transition-all duration-500 hover:border-blue-500/30 hover:bg-blue-500/[0.05] group/item cursor-default shadow-2xl">
            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-blue-500/10 text-blue-400 shadow-[0_0_20px_rgba(59,130,246,0.15)] transition-transform duration-500 group-hover/item:scale-110">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
            </div>
            <div>
              <h4 class="text-xl font-bold text-white group-hover/item:text-blue-300 transition-colors whitespace-nowrap">Office</h4>
              <p class="text-[10px] font-bold uppercase tracking-widest text-blue-400/60 mt-1">Administration</p>
            </div>
          </div>



        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-100% / 3)); }
  }


  .animate-marquee {
    animation: marquee 10s linear infinite;
  }

  .pause-animation {
    animation-play-state: paused;
  }
</style>

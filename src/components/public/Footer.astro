---
interface Props {
  ownerName: string;
  email: string;
  socials?: {
    github?: string;
    instagram?: string;
    linkedin?: string;
    whatsapp?: string;
    tiktok?: string;
  };
}

const { ownerName, email, socials = {} } = Astro.props;

const socialLinks = [
  {
    name: "GitHub",
    url: socials.github,
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>',
  },
  {
    name: "Instagram",
    url: socials.instagram,
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>',
  },
  {
    name: "LinkedIn",
    url: socials.linkedin,
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>',
  },
  {
    name: "WhatsApp",
    url: socials.whatsapp,
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
  },
  {
    name: "TikTok",
    url: socials.tiktok,
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>',
  },
].filter((s) => s.url && s.url.trim() !== "");
---

<footer
  class="relative border-t border-white/5 bg-[#030303] px-8 pt-32 pb-16 sm:px-12 lg:px-20 overflow-hidden"
>
  <!-- Subtle Background Glow -->
  <div
    class="absolute right-0 bottom-0 h-[400px] w-[400px] bg-cyan-500/5 blur-[120px] pointer-events-none"
  >
  </div>

  <div class="mx-auto max-w-7xl relative z-10">
    <div class="grid gap-20 lg:grid-cols-[2fr_1fr_1fr_1fr] lg:gap-32">
      <!-- Brand Section -->
      <div class="space-y-8">
        <div
          class="flex items-center gap-4 text-sm font-black uppercase tracking-[0.3em] text-white"
        >
          <div
            class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 overflow-hidden"
          >
            <img
              src="/logo.svg"
              alt={`${ownerName} logo`}
              class="h-10 w-10 rounded-full invert"
            />
          </div>
          {ownerName}
        </div>
        <p class="max-w-xs text-base leading-relaxed text-slate-500">
          Membangun pengalaman digital premium melalui arsitektur yang bersih
          dan rekayasa perangkat lunak modern.
        </p>
        <div class="flex flex-wrap gap-4">
          {
            socialLinks.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.name}
                class="group flex h-10 w-10 items-center justify-center rounded-full border border-white/5 bg-white/5 text-slate-400 transition-all hover:border-cyan-500/50 hover:bg-white/10 hover:text-white"
              >
                <Fragment set:html={social.icon} />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Links Sections -->
      <div class="space-y-10">
        <h4
          class="text-[10px] font-bold uppercase tracking-[0.4em] text-white/40"
        >
          Beranda
        </h4>
        <ul class="space-y-5 text-sm font-medium text-slate-500">
          <li>
            <a href="/#keahlian" class="hover:text-cyan-400 transition-colors"
              >Keahlian</a>
          </li>
          <li>
            <a href="/#karya" class="hover:text-cyan-400 transition-colors"
              >Karya Terpilih</a>
          </li>
          <li>
            <a href="/#pengalaman" class="hover:text-cyan-400 transition-colors"
              >Ringkasan Pengalaman</a>
          </li>
          <li>
            <a
              href="/#sertifikasi"
              class="hover:text-cyan-400 transition-colors">Sertifikat</a>
          </li>
        </ul>
      </div>

      <div class="space-y-10">
        <h4
          class="text-[10px] font-bold uppercase tracking-[0.4em] text-white/40"
        >
          Eksplorasi
        </h4>
        <ul class="space-y-5 text-sm font-medium text-slate-500">
          <li>
            <a href="/pengalaman" class="hover:text-cyan-400 transition-colors"
              >Semua Pengalaman</a>
          </li>
          <li>
            <a href="/proyek" class="hover:text-cyan-400 transition-colors"
              >Portofolio Lengkap</a>
          </li>
          <li>
            <a href="/sertifikat" class="hover:text-cyan-400 transition-colors"
              >Semua Sertifikat</a>
          </li>
        </ul>
      </div>

      <div class="space-y-10">
        <h4
          class="text-[10px] font-bold uppercase tracking-[0.4em] text-white/40"
        >
          Sistem & Kontak
        </h4>
        <ul class="space-y-5 text-sm font-medium text-slate-500">
          <li>
            <a
              href={`mailto:${email}`}
              class="hover:text-white transition-colors underline-offset-8 hover:underline"
              >Surel Resmi</a>
          </li>
          <li>
            <a
              href="/admin"
              class="group flex items-center gap-2 hover:text-white transition-colors"
            >
              Konsol Admin
              <span
                class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"
              ></span>
            </a>
          </li>
          <li>
            <a href="/admin" class="hover:text-white transition-colors"
              >Hub Otentikasi</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div
      class="mt-32 flex flex-col items-center justify-between border-t border-white/5 pt-12 md:flex-row gap-8"
    >
      <div class="flex flex-col items-center md:items-start gap-2">
        <p
          class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-600"
        >
          © {new Date().getFullYear()}
          {ownerName}. Hak cipta dilindungi.
        </p>
      </div>
      <div class="flex items-center gap-8">
        <div
          class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.2em] text-slate-600"
        >
          <span class="h-1 w-1 rounded-full bg-cyan-500"></span>
          Built with Astro
        </div>
        <div
          class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.2em] text-slate-600"
        >
          <span class="h-1 w-1 rounded-full bg-emerald-500"></span>
          Edge by Cloudflare
        </div>
      </div>
    </div>
  </div>
</footer>

---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="relative mt-12 lg:mt-0 perspective-1000">
  <div
    id="heroCard"
    class="relative z-10 aspect-square w-full max-w-[300px] sm:max-w-[400px] mx-auto transition-transform duration-300 ease-out preserve-3d"
  >
    <!-- The Subject (Circular Frame) -->
    <div class="relative h-full flex items-center justify-center rounded-full overflow-hidden border border-white/10 bg-black shadow-inner">

      <!-- High-Performance Shadow Layer -->
      <div class="absolute inset-0 bg-cyan-500/10 blur-[40px] pointer-events-none"></div>
      
      <img
        src="/profile.webp"
        alt={`${title} profile picture`}
        class="h-full w-auto max-w-none object-contain translate-z-50 relative z-10 lg:drop-shadow-[0_10px_20px_rgba(34,211,238,0.2)] will-change-[filter]"
        fetchpriority="high"
        loading="eager"
        width="400"
        height="400"
      />

      <!-- Soft Bottom Fade for Professional Look -->
      <div class="absolute inset-0 z-20 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-60"></div>
    </div>

    <!-- Floating Info Cards -->
    <div
      class="absolute left-10 top-10 lg:left-auto lg:right-6 lg:top-12 z-20 w-28 lg:w-36 translate-z-100 rounded-md border border-white/10 bg-black/80 p-2.5 lg:p-3 shadow-2xl backdrop-blur-xl"
    >
      <div class="flex items-center gap-2 lg:gap-2.5">
        <div
          class="h-7 w-7 lg:h-8 lg:w-8 rounded-sm bg-cyan-500/20 flex items-center justify-center text-cyan-400"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            class="lg:w-4 lg:h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><polyline points="16 18 22 12 16 6"></polyline><polyline
              points="8 6 2 12 8 18"></polyline></svg
          >
        </div>
        <div>
          <p
            class="text-[7px] lg:text-[8px] font-medium uppercase tracking-widest text-slate-400"
          >
            Keahlian
          </p>
          <p
            class="text-[9px] lg:text-xs font-semibold text-white leading-none mt-0.5"
          >
            Full-Stack
          </p>
        </div>
      </div>
    </div>

    <div
      class="absolute right-10 bottom-10 lg:right-auto lg:left-6 lg:bottom-12 z-20 w-28 lg:w-36 translate-z-150 rounded-md border border-white/10 bg-black/80 p-2.5 lg:p-3 shadow-2xl backdrop-blur-xl"
    >
      <div class="flex items-center gap-2 lg:gap-2.5">
        <div
          class="h-7 w-7 lg:h-8 lg:w-8 rounded-sm bg-emerald-500/20 flex items-center justify-center text-emerald-400"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            class="lg:w-4 lg:h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path></svg
          >
        </div>
        <div>
          <p
            class="text-[7px] lg:text-[8px] font-medium uppercase tracking-widest text-slate-500"
          >
            Ketersediaan
          </p>
          <p
            class="text-[9px] lg:text-xs font-semibold text-white leading-none mt-0.5"
          >
            Tersedia
          </p>
        </div>
      </div>
    </div>

    <div
      class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 -z-10 h-48 w-48 rounded-full bg-cyan-500/10 blur-[80px]"
    >
    </div>
  </div>
</div>

<style>
  .perspective-1000 {
    perspective: 2000px;
  }
  .preserve-3d {
    transform-style: preserve-3d;
  }
  .translate-z-50 {
    transform: translateZ(50px);
  }
  .translate-z-100 {
    transform: translateZ(80px);
  }
  .translate-z-150 {
    transform: translateZ(120px);
  }
</style>

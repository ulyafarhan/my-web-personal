---
import type { Keahlian } from "@/lib/content";
import { getSkillLevel } from "@/lib/public/skill-animations";

interface Props {
  skills: Keahlian[];
}

const { skills } = Astro.props;
---

<div class="skill-card flex-1 flex flex-col justify-center relative overflow-hidden rounded-md border border-white/[0.06] bg-white/[0.02] p-8 backdrop-blur-sm transition-all duration-700 hover:border-violet-500/20">
  <div class="flex items-center justify-between mb-8">
    <h4 class="text-[9px] font-black uppercase tracking-[0.4em] text-white/20">Skill Tracker</h4>
    <div class="flex items-center gap-2 text-[9px] font-bold uppercase tracking-[0.2em] text-white/15">
      <span class="h-1.5 w-1.5 rounded-full bg-violet-400 animate-pulse"></span>
      Live Data
    </div>
  </div>

  <div class="space-y-5">
    {skills.slice(0, 8).map((skill) => {
      const barColor = skill.warna || '#8b5cf6';
      const level = getSkillLevel(skill.persentase);
      return (
        <div class="skill-bar-item group/bar" data-percentage={skill.persentase}>
          <div class="flex items-center justify-between mb-2.5">
            <div class="flex items-center gap-3">
              <div 
                class="flex h-7 w-7 items-center justify-center rounded-full border border-white/[0.06] bg-white/[0.03] text-[10px] font-black transition-all duration-300 group-hover/bar:scale-110"
                style={`color: ${barColor}; border-color: ${barColor}33;`}
              >
                {level.rank}
              </div>
              <span class="text-[13px] font-bold text-white/70 group-hover/bar:text-white transition-colors">{skill.nama}</span>
              {skill.kategori && (
                <span class="hidden sm:inline text-[8px] font-bold uppercase tracking-[0.3em] text-white/15 border border-white/[0.04] px-2 py-0.5 rounded-full">{skill.kategori}</span>
              )}
            </div>
            <div class="flex items-center gap-3">
              <span class="text-[9px] font-bold uppercase tracking-widest text-white/15">{level.label}</span>
              <span class="skill-percent text-[13px] font-mono font-black tabular-nums text-white/40 group-hover/bar:text-white transition-colors" data-target={skill.persentase}>0%</span>
            </div>
          </div>
          <div class="relative h-2 w-full rounded-full bg-white/[0.03] overflow-hidden">
            <div class="skill-bar-glow absolute inset-y-0 left-0 rounded-full blur-md opacity-0 transition-opacity duration-1000" style={`background: ${barColor}; width: 0%;`} data-width={skill.persentase}></div>
            <div class="skill-bar absolute inset-y-0 left-0 rounded-full" style={`width: 0%; background: linear-gradient(90deg, ${barColor}99, ${barColor}); box-shadow: 0 0 8px ${barColor}30;`} data-width={skill.persentase}></div>
          </div>
        </div>
      );
    })}
  </div>
</div>

---
/**
 * ExperienceFlow.astro
 * Recreating the high-end 'Circuit/Processor' flow with 3D depth
 */
const steps = [
  { 
    id: "01", 
    label: "Penemuan", 
    desc: "Memahami batasan dan tujuan proyek dengan presisi tinggi.",
    color: "#06b6d4" // Cyan
  },
  { 
    id: "02", 
    label: "Arsitektur", 
    desc: "Merancang sistem cloud-native yang bersih dan skalabel.",
    color: "#a855f7" // Purple
  },
  { 
    id: "03", 
    label: "Pengembangan", 
    desc: "Menulis kode berperforma tinggi dengan standar industri.",
    color: "#10b981" // Emerald
  },
  { 
    id: "04", 
    label: "Peluncuran", 
    desc: "Distribusi global melalui jaringan edge terotomatisasi.",
    color: "#3b82f6" // Blue
  }
];
---

<section id="alur-kerja" class="workflow-section relative py-32 px-8 sm:px-12 lg:px-20 overflow-hidden bg-transparent perspective-2000">
  <!-- Ambient Background Light -->
  <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-[1000px] w-[1000px] bg-cyan-500/[0.03] blur-[150px] pointer-events-none"></div>

  <div class="mx-auto max-w-7xl relative z-10">
    <div class="text-center mb-32">
      <h2 class="text-[10px] font-bold uppercase tracking-[0.6em] text-cyan-400 mb-6">Mesin Penggerak</h2>
      <h3 class="text-4xl font-black text-white sm:text-6xl tracking-tight leading-tight">
        Alur Kerja <span class="text-transparent bg-clip-text bg-gradient-to-r from-slate-400 to-slate-600">Standar Produksi</span>
      </h3>
    </div>

    <!-- The 3D Circuit System -->
    <div class="relative flex flex-col items-center">
      
      <!-- Central Hub (The 3D CPU) -->
      <div class="relative z-30 mb-28 group/cpu">
        <div class="cpu-3d-container preserve-3d transition-transform duration-700 group-hover/cpu:rotate-x-12 group-hover/cpu:scale-110">
            <!-- CPU Base Plate -->
            <div class="absolute inset-0 -translate-z-4 bg-white/5 rounded-md blur-sm scale-105"></div>
            
            <div class="cpu-core relative flex h-28 w-56 items-center justify-center rounded-md border border-white/20 bg-[#080808] shadow-[0_40px_80px_rgba(0,0,0,0.8)] overflow-hidden">
               <div class="absolute inset-0 bg-gradient-to-br from-white/[0.08] to-transparent"></div>
               
               <!-- Internal Circuit Pattern -->
               <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
               
               <div class="flex flex-col items-center gap-1 relative z-10">
                  <span class="text-[8px] font-bold tracking-[0.4em] text-cyan-500/60 uppercase">System Hub</span>
                  <span class="text-sm font-black tracking-[0.2em] text-white uppercase">DITENAGAI OLEH</span>
               </div>
               
               <!-- Glowing Lines -->
               <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-cyan-400/50 to-transparent animate-scan-h"></div>
               
               <!-- CPU Pins (Realistic Gold/Silver look) -->
               <div class="absolute -left-1 top-1/2 -translate-y-1/2 flex flex-col gap-2.5">
                  <div class="h-[3px] w-4 bg-gradient-to-r from-cyan-400/40 to-transparent rounded-full shadow-[0_0_5px_rgba(34,211,238,0.2)]"></div>
                  <div class="h-[3px] w-4 bg-gradient-to-r from-cyan-400/40 to-transparent rounded-full"></div>
                  <div class="h-[3px] w-4 bg-gradient-to-r from-cyan-400/40 to-transparent rounded-full"></div>
               </div>
               <div class="absolute -right-1 top-1/2 -translate-y-1/2 flex flex-col gap-2.5">
                  <div class="h-[3px] w-4 bg-gradient-to-l from-cyan-400/40 to-transparent rounded-full shadow-[0_0_5px_rgba(34,211,238,0.2)]"></div>
                  <div class="h-[3px] w-4 bg-gradient-to-l from-cyan-400/40 to-transparent rounded-full"></div>
                  <div class="h-[3px] w-4 bg-gradient-to-l from-cyan-400/40 to-transparent rounded-full"></div>
               </div>
            </div>
        </div>
      </div>

      <!-- Advanced Circuit SVG (Desktop) -->
      <svg class="absolute top-14 left-0 w-full h-[350px] pointer-events-none hidden lg:block" viewBox="0 0 1200 350" fill="none">
        <defs>
          <filter id="glow-cyan" x="-20%" y="-20%" width="140%" height="140%"><feGaussianBlur stdDeviation="4" result="blur" /><feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge></filter>
          <filter id="glow-purple" x="-20%" y="-20%" width="140%" height="140%"><feGaussianBlur stdDeviation="4" result="blur" /><feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge></filter>
          <filter id="glow-emerald" x="-20%" y="-20%" width="140%" height="140%"><feGaussianBlur stdDeviation="4" result="blur" /><feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge></filter>
          <filter id="glow-blue" x="-20%" y="-20%" width="140%" height="140%"><feGaussianBlur stdDeviation="4" result="blur" /><feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge></filter>
        </defs>
        <!-- High-Tech Circuit Paths -->
        <g class="circuit-layer opacity-20">
            <path d="M600 20V100H200V250" stroke="white" stroke-width="1.5" stroke-dasharray="4 4" />
            <path d="M600 20V120H500V250" stroke="white" stroke-width="1.5" stroke-dasharray="4 4" />
            <path d="M600 20V120H700V250" stroke="white" stroke-width="1.5" stroke-dasharray="4 4" />
            <path d="M600 20V100H1000V250" stroke="white" stroke-width="1.5" stroke-dasharray="4 4" />
        </g>
        
        <!-- Energy Pulse Layer -->
        <path d="M600 20V100H200V250" class="energy-path" stroke="#06b6d4" stroke-width="4" stroke-linecap="round" filter="url(#glow-cyan)" />
        <path d="M600 20V120H500V250" class="energy-path" stroke="#a855f7" stroke-width="4" stroke-linecap="round" filter="url(#glow-purple)" />
        <path d="M600 20V120H700V250" class="energy-path" stroke="#10b981" stroke-width="4" stroke-linecap="round" filter="url(#glow-emerald)" />
        <path d="M600 20V100H1000V250" class="energy-path" stroke="#3b82f6" stroke-width="4" stroke-linecap="round" filter="url(#glow-blue)" />
      </svg>

      <!-- Vertical Circuit SVG (Mobile Simplified) -->
      <svg class="absolute top-20 left-1/2 -translate-x-1/2 w-full h-full pointer-events-none lg:hidden" viewBox="0 0 100 800" fill="none" preserveAspectRatio="none">
        <path d="M50 0 V800" stroke="white" stroke-opacity="0.05" stroke-width="1" stroke-dasharray="4 4" />
        <path d="M50 0 V800" class="energy-path-mobile" stroke="#06b6d4" stroke-width="2" stroke-linecap="round" />
      </svg>


      <div class="relative z-20 grid gap-8 md:grid-cols-2 lg:grid-cols-4 w-full">
        {steps.map((step, idx) => (
          <div class="workflow-card group relative p-10 rounded-md border border-white/5 bg-[#050505] shadow-2xl transition-all duration-700 hover:scale-[1.02] hover:-translate-y-2 overflow-hidden" style={`--spotlight-color: ${step.color}25;`}>
             <!-- Deep Inner Shadow for 3D Feel -->
             <div class="absolute inset-0 bg-gradient-to-b from-white/[0.02] to-transparent pointer-events-none"></div>
             
             <!-- Corner Accent -->
             <div class="absolute top-0 right-0 h-16 w-16 opacity-10 transition-opacity group-hover:opacity-30" style={`background: radial-gradient(circle at top right, ${step.color}, transparent 70%)`}></div>

             <div class="mb-10 relative">
                <!-- Icon Module -->
                <div class="h-14 w-14 flex items-center justify-center rounded-md border border-white/10 bg-white/[0.03] text-white shadow-inner transition-all duration-500 group-hover:border-white/20 group-hover:bg-white/5 group-hover:rotate-[10deg]" style={`--glow: ${step.color}`}>
                   {idx === 0 && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>}
                   {idx === 1 && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>}
                   {idx === 2 && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>}
                   {idx === 3 && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>}
                   
                   <!-- Glow Effect on Hover -->
                   <div class="absolute inset-0 rounded-md opacity-0 group-hover:opacity-40 blur-lg transition-opacity duration-500" style={`background: ${step.color}`}></div>
                </div>
                
                <!-- Numeric Badge -->
                <span class="absolute -right-2 -top-2 text-[10px] font-mono text-white/20 font-black">{step.id}</span>
             </div>

             <h4 class="text-2xl font-black text-white mb-4 transition-colors group-hover:text-white">
                {step.label}
             </h4>
             <p class="text-sm leading-relaxed text-slate-500 group-hover:text-slate-300 transition-colors duration-500">
                {step.desc}
             </p>
             <!-- Spotlight Overlay -->
             <div class="spotlight-layer pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-500 bg-[radial-gradient(circle_at_var(--x)_var(--y),_var(--spotlight-color),_transparent_80%)] group-hover:opacity-100"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .perspective-2000 { perspective: 2000px; }
  .preserve-3d { transform-style: preserve-3d; }
  .-translate-z-4 { transform: translateZ(-10px); }

  .cpu-core {
    background: radial-gradient(circle at center, #0a0a0a 0%, #050505 100%);
  }

  @keyframes scan-h {
    0% { transform: translateY(0); opacity: 0; }
    50% { opacity: 1; }
    100% { transform: translateY(112px); opacity: 0; }
  }
  .animate-scan-h {
    animation: scan-h 3s linear infinite;
  }

  .energy-path {
    stroke-dasharray: 150, 200;
    stroke-dashoffset: 350;
    animation: flow 2.5s linear infinite;
  }

  .energy-path-mobile {
    stroke-dasharray: 200, 250;
    stroke-dashoffset: 450;
    animation: flow-mobile 2.5s linear infinite;
  }

  @keyframes flow {
    0% { stroke-dashoffset: 350; }
    100% { stroke-dashoffset: 0; }
  }

  @keyframes flow-mobile {
    0% { stroke-dashoffset: 450; }
    100% { stroke-dashoffset: 0; }
  }

  .rotate-x-12 { transform: rotateX(15deg); }

  .spotlight-layer {
    --x: 0px;
    --y: 0px;
  }
</style>

<script>
  function initSpotlight() {
    const cards = document.querySelectorAll('.workflow-card');
    
    cards.forEach(card => {
      card.addEventListener('mousemove', (event) => {
        const e = event as MouseEvent;
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        (card as HTMLElement).style.setProperty('--x', `${x}px`);
        (card as HTMLElement).style.setProperty('--y', `${y}px`);
      });
    });
  }

  // Initialize
  initSpotlight();
</script>

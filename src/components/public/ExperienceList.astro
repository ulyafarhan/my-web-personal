---
import type { PengalamanIT } from '@/lib/content';

interface Props {
  experiences: PengalamanIT[];
}

const { experiences = [] } = Astro.props;
---

{experiences.length > 0 && (
  <section id="pengalaman" class="reveal relative py-32 px-8 sm:px-12 lg:px-20 overflow-hidden font-['Outfit']">
    <div class="mx-auto max-w-7xl relative z-10">
      <div class="mb-20 text-center lg:text-left">
          <h2 class="text-[10px] font-black uppercase tracking-[0.6em] text-cyan-400">Jejak Karir</h2>
          <h3 class="mt-4 text-4xl font-black text-white sm:text-6xl tracking-tight leading-tight">Pengalaman <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-emerald-400">Profesional.</span></h3>
      </div>

      <div class="grid gap-6">
        {experiences.map((exp, idx) => (
          <div class="group relative overflow-hidden rounded-md border border-white/5 bg-[#080808] p-8 md:p-10 transition-all duration-700 hover:border-cyan-500/30 hover:-translate-y-1 shadow-2xl">
            <!-- Glow Effect -->
            <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/0 to-cyan-500/0 group-hover:from-cyan-500/5 group-hover:to-transparent transition-all duration-700 pointer-events-none"></div>
            
            <div class="relative z-10 flex flex-col md:flex-row md:items-start md:justify-between gap-6">
              <div class="flex-1">
                <h4 class="text-2xl font-black text-white mb-2 group-hover:text-cyan-400 transition-colors duration-500">{exp.peran}</h4>
                <div class="flex items-center gap-3 text-sm font-semibold text-slate-400 mb-6">
                  <span class="text-white">{exp.organisasi}</span>
                  <span class="h-1 w-1 rounded-full bg-slate-600"></span>
                  <span class="text-cyan-500/80">{exp.periode}</span>
                </div>
                <p class="text-base text-slate-500 leading-relaxed whitespace-pre-wrap max-w-3xl">{exp.deskripsi}</p>
              </div>
              
              <div class="hidden md:flex flex-col items-end justify-start opacity-20 group-hover:opacity-100 transition-opacity duration-700">
                <div class="h-12 w-12 rounded-full border border-cyan-500/20 flex items-center justify-center bg-cyan-500/5">
                   <span class="text-cyan-400 font-mono text-[10px] font-black">{idx + 1 < 10 ? `0${idx + 1}` : idx + 1}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a href="/pengalaman" class="group relative inline-flex items-center gap-3 overflow-hidden rounded-full border border-cyan-500/30 bg-cyan-500/10 px-8 py-3.5 text-[11px] font-black uppercase tracking-[0.2em] text-cyan-400 transition-all hover:bg-cyan-500 hover:text-black">
          <span class="relative z-10">Lihat Semua Pengalaman</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="relative z-10 transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
)}
